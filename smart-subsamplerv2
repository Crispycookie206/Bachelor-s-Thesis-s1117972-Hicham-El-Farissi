import sys
import cv2
import numpy
from pathlib import Path

## DECLARATION
## boilerplate code for importing libraries and their specific commands, the BT. 709 conversion formula coefficients, standard function definitions and file handling were generated or derived from examples generated by AI, 
# all logical design of the subsampling algorithm, its structure and functions and resulting choices for complexity measurement, case identification and pixel selection are my original work.

input_image = cv2.imread(sys.argv[1]) 
threshold = int(sys.argv[2])
image = cv2.cvtColor(input_image, cv2.COLOR_BGR2RGB).astype('float32')
height, width, _ = image.shape

RedPlane = image[:, :, 0]
GreenPlane = image[:, :, 1]
BluePlane = image[:, :, 2]

Y = 0.2126 * RedPlane + 0.7152 * GreenPlane + 0.0722 * BluePlane
Cb = -0.1146 * RedPlane - 0.3854 * GreenPlane + 0.5000 * BluePlane + 128
Cr = 0.5000 * RedPlane - 0.4542 * GreenPlane - 0.0458 * BluePlane + 128

Cb_output = numpy.zeros((height // 2, width // 2), dtype=numpy.float32)
Cr_output = numpy.zeros((height // 2, width // 2), dtype=numpy.float32)

# Constants used in recognition system

# the threshold for initiation smart mode, where blocks are actively analysed for a concrete pattern.
COMPLEXITY_THRESHOLD = 10

CHROMA_MARGIN = 10

# New similarity function that gives the distance accross chroma values, used in the actual comparison functions later
def chromaSimilarityEuclidianDistance(blueBlock, redBlock, point1, point2):

    blueSpread = blueBlock[point1] - blueBlock[point2]
    redSpread = redBlock[point1] - redBlock[point2]

    return (blueSpread**2 + redSpread**2)**0.5

# New complexity function that uses the 3d maximum spread
def measureComplexity(y_block, cb_block, cr_block):

    y_diff = y_block.max() - y_block.min()
    cb_diff = cb_block.max() - cb_block.min()
    cr_diff = cr_block.max() - cr_block.min()

    return max(y_diff, cb_diff, cr_diff)

# actual comparison checker for similarity, split up for ease of use
def similarChromaValues(cb_block, cr_block, point1, point2):
    if chromaSimilarityEuclidianDistance(cb_block, cr_block, point1, point2) < CHROMA_MARGIN:
        return True
    else:        return False
    
# actual comparison checker for similarity, split up for ease of use
def differentChromaValues(cb_block, cr_block, point1, point2):
    if chromaSimilarityEuclidianDistance(cb_block, cr_block, point1, point2) >= CHROMA_MARGIN:
        return True
    else:        return False

# Identifier system that scans a block and outputs the pattern it belongs to. Always falls back to Smooth if complexity is low.
def patternRecognition(y_block, cb_block, cr_block, complexity_score):
    if complexity_score < COMPLEXITY_THRESHOLD:
        return "SMOOTH", None

    tlbr = similarChromaValues(cb_block, cr_block, (0,0), (1,1)) and differentChromaValues(cb_block, cr_block, (0,0), (0,1))
    trbl = similarChromaValues(cb_block, cr_block, (0,1), (1,0)) and differentChromaValues(cb_block, cr_block, (0,1), (0,0))

    if tlbr and trbl:
        if y_block[0,0] > y_block[0,1]: 
            return "DIAGONAL", "TLBR"
        else:
            return "DIAGONAL", "TRBL"
    elif tlbr:
        return "DIAGONAL", "TLBR"
    elif trbl:
        return "DIAGONAL", "TRBL"

    if similarChromaValues(cb_block, cr_block, (0,0), (0,1)) and similarChromaValues(cb_block, cr_block, (0,0), (1,0)) and differentChromaValues(cb_block, cr_block, (0,0), (1,1)):
        return "CORNER", (1, 1)
    elif similarChromaValues(cb_block, cr_block, (0,0), (0,1)) and similarChromaValues(cb_block, cr_block, (0,0), (1,1)) and differentChromaValues(cb_block, cr_block, (0,0), (1,0)):
        return "CORNER", (1, 0)
    elif similarChromaValues(cb_block, cr_block, (0,0), (1,0)) and similarChromaValues(cb_block, cr_block, (0,0), (1,1)) and differentChromaValues(cb_block, cr_block, (0,0), (0,1)):
        return "CORNER", (0, 1)
    elif similarChromaValues(cb_block, cr_block, (0,1), (1,0)) and similarChromaValues(cb_block, cr_block, (0,1), (1,1)) and differentChromaValues(cb_block, cr_block, (0,1), (0,0)):
        return "CORNER", (0, 0)

    if similarChromaValues(cb_block, cr_block, (0,0), (0,1)) and differentChromaValues(cb_block, cr_block, (0,0), (1,0)):
        if y_block[0,0] + y_block[0,1] >= y_block[1,0] + y_block[1,1]: #pick brighter side

            return "EDGEHOR", "top"
        else:
            return "EDGEHOR", "bottom"

    if similarChromaValues(cb_block, cr_block, (0,0), (1,0)) and differentChromaValues(cb_block, cr_block, (0,0), (0,1)):
        if y_block[0,0] + y_block[1,0] >= y_block[0,1] + y_block[1,1]: #pick brighter side
            return "EDGEVER", "left"
        else:
            return "EDGEVER", "right"
    
    return "CHAOS", None

def giveBrightestPixel(y_block):
    flattenedBlock = y_block.flatten()
    brightestPixel = flattenedBlock.argmax()
    return numpy.unravel_index(brightestPixel, (2, 2))

# extra distribution information to print later print to use for analysis after testing.
case_counts = {"SMOOTH": 0, "EDGEHOR": 0, "EDGEVER": 0, "DIAGONAL": 0, "CORNER": 0, "CHAOS": 0}

# MAIN BLOCK PROCESSING LOOP
for y in range(0, height, 2):
    for x in range(0, width, 2):

        # split 3d block
        y_block = Y[y:y+2, x:x+2]
        cb_block = Cb[y:y+2, x:x+2]
        cr_block = Cr[y:y+2, x:x+2]

        case, specificChoice = patternRecognition(y_block, cb_block, cr_block, measureComplexity(y_block, cb_block, cr_block))
        case_counts[case] += 1

        if case == "SMOOTH":
            Cb_output[y//2, x//2] = cb_block[giveBrightestPixel(y_block)]
            Cr_output[y//2, x//2] = cr_block[giveBrightestPixel(y_block)]

        elif case == "DIAGONAL" and specificChoice == "TLBR":
            Cb_output[y//2, x//2] = cb_block[0, 0]
            Cr_output[y//2, x//2] = cr_block[0, 0]
        elif case == "DIAGONAL" and specificChoice == "TRBL":
            Cb_output[y//2, x//2] = cb_block[0, 1]
            Cr_output[y//2, x//2] = cr_block[0, 1]
        elif case == "CORNER":
            Cb_output[y//2, x//2] = cb_block[specificChoice]
            Cr_output[y//2, x//2] = cr_block[specificChoice]
        elif case == "EDGEHOR" and specificChoice == "top":
            Cb_output[y//2, x//2] = cb_block[0, 0]
            Cr_output[y//2, x//2] = cr_block[0, 0]
        elif case == "EDGEHOR" and specificChoice == "bottom":
            Cb_output[y//2, x//2] = cb_block[1, 0]
            Cr_output[y//2, x//2] = cr_block[1, 0]
        elif case == "EDGEVER" and specificChoice == "left":
            Cb_output[y//2, x//2] = cb_block[0, 0]
            Cr_output[y//2, x//2] = cr_block[0, 0]
        elif case == "EDGEVER" and specificChoice == "right":
            Cb_output[y//2, x//2] = cb_block[0, 1]
            Cr_output[y//2, x//2] = cr_block[0, 1]
        else:
            Cb_output[y//2, x//2] = cb_block[giveBrightestPixel(y_block)]
            Cr_output[y//2, x//2] = cr_block[giveBrightestPixel(y_block)]

print(f"Case counts: {case_counts}")

def upsampleNearestNeighbor(downsampledPlane):
    fullResolution = numpy.zeros((height, width), dtype=numpy.float32)
    for y in range(downsampledPlane.shape[0]):
        for x in range(downsampledPlane.shape[1]):
            color = downsampledPlane[y, x]
            fullResolution[y*2 : y*2+2, x*2 : x*2+2] = color
    return fullResolution

cb_final = upsampleNearestNeighbor(Cb_output)
cr_final = upsampleNearestNeighbor(Cr_output)

def conversionBackToRGB(y, cb, cr):
    cb_og = cb - 128
    cr_og = cr - 128
    r = y + 1.5748 * cr_og
    g = y - 0.1873 * cb_og - 0.4681 * cr_og
    b = y + 1.8556 * cb_og
    return numpy.clip([r, g, b], 0, 255).astype(numpy.uint8)

finalRGBArray = numpy.transpose(conversionBackToRGB(Y, cb_final, cr_final), (1, 2, 0))
final_bgr = cv2.cvtColor(finalRGBArray, cv2.COLOR_RGB2BGR)

input_path = Path(sys.argv[1])
inputStem = input_path.stem
output_location = Path("smart-output")
output_location.mkdir(exist_ok=True)
output_path = str(output_location / f"{inputStem}-smart-output.png")

cv2.imwrite(output_path, final_bgr)
print(f"image saved as {output_path}")
